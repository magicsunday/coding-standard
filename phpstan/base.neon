# Shared PHPStan base configuration for magicsunday/* projects.
#
# The rule extensions (phpstan-strict-rules, phpstan-deprecation-rules,
# phpstan-phpunit, phpat) are auto-registered through phpstan/extension-installer,
# which magicsunday/coding-standard depends on — so they do NOT need to be listed
# here. The consumer's composer.json must allow the plugin:
#
#     "config": { "allow-plugins": { "phpstan/extension-installer": true } }
#
# Consumer phpstan.neon:
#
#     includes:
#         - vendor/magicsunday/coding-standard/phpstan/base.neon
#     parameters:
#         phpVersion: 80300
#         paths:
#             - src
#             - tests
#     services:
#         -
#             class: Vendor\Namespace\Test\Architecture\ArchitectureTest
#             tags:
#                 - phpat.test
parameters:
    # 0 is the loosest, 10 (max) the strictest.
    level: max

    fileExtensions:
        - php

    phpat:
        show_rule_names: true
