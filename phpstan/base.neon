# Shared PHPStan base configuration for magicsunday/* projects.
#
# The rule extensions are included explicitly by paths relative to THIS file, so
# the config is valid in every context that loads it — the main PHPStan run and
# Rector's phpstanConfig alike (a param like `phpat.show_rule_names` is only
# schema-valid where phpat's extension.neon is loaded, which extension-installer
# does NOT guarantee for Rector). The relative `../../../<vendor-package>` paths
# resolve regardless of the consumer's vendor-dir (`vendor` or `.build/vendor`).
#
# Consumer phpstan.neon:
#
#     includes:
#         - vendor/magicsunday/coding-standard/phpstan/base.neon
#     parameters:
#         phpVersion: 80300
#         paths:
#             - src
#             - tests
#     services:
#         -
#             class: Vendor\Namespace\Test\Architecture\ArchitectureTest
#             tags:
#                 - phpat.test
includes:
    - ../../../phpstan/phpstan-strict-rules/rules.neon
    - ../../../phpstan/phpstan-deprecation-rules/rules.neon
    - ../../../phpstan/phpstan-phpunit/extension.neon
    - ../../../phpstan/phpstan-phpunit/rules.neon
    - ../../../phpat/phpat/extension.neon

parameters:
    # 0 is the loosest, 10 (max) the strictest.
    level: max

    # Distrust PHPDoc types the engine cannot prove. Without this, a wrong or
    # widened @var/@param silently becomes the analysed truth and hides the very
    # mismatch it should surface.
    treatPhpDocTypesAsCertain: false

    fileExtensions:
        - php

    phpat:
        show_rule_names: true
