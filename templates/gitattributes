# Shared .gitattributes for magicsunday/* projects. Copy to `.gitattributes` at
# the repo root and add repo-specific entries. Keeps the Composer/npm dist
# archive lean by export-ignoring dev-only tooling, tests and CI config.
/.build                     export-ignore
/.github                    export-ignore
/tests                      export-ignore
/.editorconfig              export-ignore
/.gitattributes             export-ignore
/.gitignore                 export-ignore
/.jscpd.json                export-ignore
/.php-cs-fixer.dist.php     export-ignore
/.phplint.yml               export-ignore
/AGENTS.md                  export-ignore
/infection.json5            export-ignore
/phpstan.neon               export-ignore
/phpstan-scripts.neon       export-ignore
/phpunit.xml.dist           export-ignore
/rector.php                 export-ignore
